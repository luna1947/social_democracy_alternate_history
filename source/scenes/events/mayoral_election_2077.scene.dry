@round2_petrov
view-if: ip_support_petrov == 0 and cp_support_rovich == 0
choose-if: cp_relation >= 50 and left_strength > reformist_strength 
unavailable-subtitle: [? if cp_relation < 50 : We do not have good enough relations with the Communists, so they are not even willing to accept our support. ?] [? if reformist_strength >= left_strength : The reformist faction is able to dissuade the party from supporting this bizarre arrangement. ?]
