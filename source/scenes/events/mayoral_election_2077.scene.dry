@round2_petrov_2
on-arrival: rovich_campaign = 0; ip_support_petrov = 1; reformist_dissent += 15; Federalists_dissent += 10; labor_dissent += 5; neorevisionist_dissent += 10; catholics_ip -= 5; workers_ip -= 3; cp_relation += 10; communist_coalition += 2; fp_relation -= 15; lp_relation -= 15
