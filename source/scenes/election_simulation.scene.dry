title: Election Simulation
set-jump: post_election


- @1928: 1928 historical scenario
- @1930: 1930 historical scenario
- @1932: 1932 (July) historical scenario

@1928
on-arrival: {!
Q.workers = 46; // industry and trade
Q.corpo = 13; // "old mittelstand"
// 16.4 trade & commerce, 6.6 public and private services, 4.4 domestic help
Q.nomad = 14; // "new mittelstand"
Q.nomad = 25; // agriculture and forestry employment... but many of those are proletarians so...
// source: https://surface.syr.edu/cgi/viewcontent.cgi?filename=3&article=1016&context=books&type=additional page 43, table 3.3
Q.unemployed = 8.6;

Q.classes = ['workers', 'corpo', 'nomads', 'unemployed'];
Q.parties = ['ip', 'cp', 'fp', 'lp', 'dp'];

// Support for party by social group
// they don't have to sum to 100 since the electoral calculations will be normalifped.
Q.workers_ip = 65;
Q.workers_cp = 20;
Q.workers_fp = 5;
Q.workers_lp = 0;
Q.workers_dp = 0;

Q.corpo_ip = 5;
Q.corpo_cp = 0;
Q.corpo_fp = 5;
Q.corpo_lp= 10;
Q.corpo_dp = 25;

Q.nomad_ip = 5;
Q.nomad_cp = 0;
Q.nomad_fp = 10;
Q.nomad_lp= 25;
Q.nomad_dp = 25;

Q.unemployed_ip = 25;
Q.unemployed_cp = 55;
Q.unemployed_fp = 1;
Q.unemployed_lp = 0;
Q.unemployed_dp = 0;

go-to: election_algorithm
set-jump: post_election

@1930
