Q.nomad_ip = 5;
Q.nomad_cp = 0;
Q.nomad_fp = 5;
Q.nomad_lp = 10;
Q.nomad_dp = 20;

Q.nomad_ip = 5;
Q.nomad_cp = 0;
Q.nomad_fp = 5;
Q.nomad_lp= 5;
