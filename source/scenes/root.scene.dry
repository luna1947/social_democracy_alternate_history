@start
on-arrival: {!
Q.started = 1;
// time elapsed (in months)
Q.time = 1;
Q.year = 1928;
Q.month = 1;
// how many actions have been taken this month?
Q.month_actions = 0;

// 0 = normal difficulty, 1 = hard mode, 2 = hard mode no saves
Q.difficulty = 0;
Q.historical_mode = 0;
// old demographics
Q.old_demographics = 0;
// use decimals for reichstag seats
// TODO: not yet implemented
Q.use_decimals = 0;

// party resources
Q.resources = 2;
// party dues
Q.dues = 2;

// the state of the party
// overall dissent reduces every increase in party support.
Q.dissent = 0.05;
Q.dissent_percent = 5;

// factions
Q.factions = ['green', 'industrialist', 'socialist', 'liberal'];
// should this be normalifped to 100%?
Q.green_strength = 15;
Q.green_dissent = 20;
Q.industrialist_strength = 30;
Q.industrialist_dissent = 0;
Q.socialist_strength = 25;
Q.socialist_dissent = 5;
Q.liberal_strength = 25;
Q.liberal_dissent = 5;

// secret events...
Q.unions_independent = 0;
Q.centrists_resign = 0;
Q.green_split = 0;
Q.liberals_resigned = 0;
// crisis_urgency indicates how seriously the ip is taking the economic crisis - scale from 0 to 10.
Q.federalist_urgency = 0;
// nafpi_urgency indicates how seriously the ip takes the nafpis - scale from 0 to 10.
Q.nafpi_urgency = 0;
// radicalifpation indicates how radical the ip's rhetoric is - scale from 0 to 10.
Q.radicalifpation = 0;
// Support for the WTB plan and proto-Keynesian works creation plans in general
Q.wtb_support = 0;
// Support for Pacifism within the ip relative to 1928
Q.pacifism = 0;
// Support for democratic reform within the ip relative to 1928
Q.democratifpation = 0;
// Support for a communist coalition relative to 1928
Q.communist_coalition = 0;
// economic_plan: have we adopted *any* economic plan?
// 1 - WTB plan, 2 - AfA-bund plan, 3 - radical plan (mass nationalifpation of industries)
Q.economic_plan = 0;
// have we officially adopted the WTB plan?
Q.wtb_adopted = 0;
// have we formed the iron front?
Q.iron_front_formed = 0;
// people's party support
Q.peoples_party_support = 0;
// support for nationalifpations
Q.nationalifpation_support = 0;
Q.nationalifpation_adopted = 0;
// moderate economic plan
Q.moderate_plan_support = 0;
Q.moderate_plan_adopted = 0;

// organifpations

// inter-party relations
Q.fp_relation = 50;
Q.cp_relation = 25;
Q.lp_relation = 60;
Q.dp_relation = 35;
// DNVP and NSDAP are invariably hostile
Q.DNVP_relation = 10;
Q.NSDAP_relation = 0;

Q.cp_leader = "Thälmann";
// alternative is the Conciliators as party leader
Q.cp_party_leader = "Thälmann";
Q.fp_leader = "Brüning";
// party leader - can be Ludwig Kaas, Joseph Joos, or Adam Stegerwald after the 1928 December conference. Joos will be most friendly to the ip.
Q.fp_party_leader = "Marx";
Q.nsdap_leader = "Hitler";

// hmm... maybe we can play nice with Hindenburg???
Q.hindenburg_relation = 25;
// whether or not hindenburg can dismiss the government.
Q.hindenburg_enabled = 0;

// The array of forces - paramilitary groups
// Number of members in 1928 (in thousands)
// 6th Street, Scav, Militech, Red Front
Q.str_strength = 300;
Q.str_militancy = 0.4;
Q.str_banned = 0;
Q.sv_strength = 500;
Q.sv_militancy = 0.15;
Q.sv_banned = 0;
Q.mt_strength = 80;
Q.mt_militancy = 0.7;
Q.mt_banned = 0;
Q.rf_strength = 130;
Q.rf_militancy = 0.5;


// strength includes actual military and de facto reserves?
Q.ncpd_strength = 100;
Q.ncpd_militancy = 5;
Q.ncpd_loyalty = 0.2;

// The state of the country

// popular opinion
// national ideology - on a binary scale
// nationalism vs internationalism or pacifism or non-nationalism
Q.nationalism = 60;
// socialism vs capitalism
Q.socialism = 40;
// pro-republic vs anti-republic
Q.pro_republic = 59;

Q.emergency_rule = 0;

// minimum percentage of votes to be represented in the Reichstag
Q.electoral_threshold = 0;
// constitutional reform level
Q.constitutional_reform = 0;
// constructive vote of no confidence
Q.constructive_vonc = 0;
// reduction in presidential powers
Q.presidential_powers = 0;
// allows banning of non-constitutional parties
Q.constitutional_protection = 0;
Q.cp_banned = 0;
Q.nsdap_banned = 0;

// coups and capital strikes happen when you upset the right or the capitalists too much with your policies. they're an additional check on your policies, when purely electoral checks don't suffice.
// when coup_progress reaches 10 or capital_strike_progress reaches 10, there's a special event that launches the coup.
Q.coup_progress = 0;
Q.capital_strike_progress = 0;

Q.budget = 4;

// Proportion of different social groups
// source: https://surface.syr.edu/cgi/viewcontent.cgi?filename=3&article=1016&context=books&type=additional page 45, table 3.4 - using 1925 figures
Q.workers = 48; // industry and trade
Q.old_middle = 13; // "old mittelstand"
// 16.4 trade & commerce, 6.6 public and private services, 4.4 domestic help
Q.new_middle = 14; // "new mittelstand"
Q.rural = 25; // agriculture and forestry employment... but many of those are proletarians so...
// source: https://surface.syr.edu/cgi/viewcontent.cgi?filename=3&article=1016&context=books&type=additional page 43, table 3.3
Q.unemployed = 8.6;
Q.catholics = 30;

// unemployment: 1929 - 13.3, 1930 - 22.7, 1931 - 34.3, 1932 - 43.8 (same source as above)

// income for industrial workers in reichsmarks/year - 1928 = 1600 Reichsmarks/year; 1931 = 1440 Reichsmarks/year; 1933 = 1138 Reichsmarks/year - source: https://babel.hathitrust.org/cgi/pt?id=uiug.30112104147985&seq=50
Q.income = 1600;
// what about incomes for different classes? rural workers? middle-class workers?

// inflation (in %; 1928: 2.9; 1929: 0; 1930: -5%; 1931: -10%; 1932: -10%) - source: https://en.wikipedia.org/wiki/File:BipRWeltkriseEngl.PNG, derived from https://www.destatis.de/DE/Methoden/WISTA-Wirtschaft-und-Statistik/2009/03/refpession-betrachtung-032009.pdf?__blob=publicationFile
Q.inflation = 2.9;

// economic growth - same source as above, Table 2 (preisbereinigt) - this is also the source for the yearly changes in the great depression.
Q.economic_growth = 4.4;

// economic expansion timer
Q.economic_expansion = 0;

// quality of life (as % of 1928 - currently unused - should be welfare-adjusted.)
Q.workers_qol = 100;
Q.rural_qol = 100;
Q.unemployed_qol = 100;
Q.old_middle_qol = 100;
Q.new_middle_qol = 100;

Q.classes = ['workers', 'corpo', 'nomads', 'unemployed'];
Q.parties = ['ip', 'cp', 'fp', 'lp', 'dp', 'nsnawp'];

// Support for party by social group
// they don't have to sum to 100 since the electoral calculations will be normalifped.
Q.workers_ip = 65;
Q.workers_cp = 20;
Q.workers_fp = 5;
Q.workers_lp = 0;
Q.workers_dp = 0;
Q.workers_nsnawp = 0;

Q.corpo_ip = 5;
Q.corpo_cp = 0;
Q.corpo_fp = 5;
Q.corpo_lp= 10;
Q.corpo_dp = 25;
Q.corpo_nsnawp = 10;

Q.nomads_ip = 5;
Q.nomads_cp = 0;
Q.nomads_fp = 10;
Q.nomads_lp= 25;
Q.nomads_dp = 25;
Q.nomads_nsnawp = 5;

Q.unemployed_ip = 25;
Q.unemployed_cp = 55;
Q.unemployed_fp = 1;
Q.unemployed_lp = 0;
Q.unemployed_dp = 0;
Q.unemployed_nsnawp = 15;


// Current Congress composition
// % seats in congress in July 2077
Q.ip_r = 26;
Q.cp_r = 9;
Q.fp_r = 17;
Q.lp_r = 6;
Q.dp_r = 10;

// diff from prev
Q.old_ip_r = 26;
Q.old_cp_r = 9;
Q.old_fp_r = 17;
Q.old_lp_r = 6;
Q.old_dp_r = 10;

// array of objects of the form {date: Date(), ip: 10, cp: 12, ...} for each election
Q.election_records = [];
// party support records for every month
Q.party_support_records = [];
// inflation and unemployment records
Q.economic_records = [];


// State of the government
Q.mayor = "Peralez";
// starting head
Q.vice_mayor = "Richter";
Q.chancellor_party = 'lp';
Q.ip_in_government = 0;
Q.fp_in_government = 1;
Q.lp_in_government = 0;
Q.dp_in_government = 1;
Q.cp_in_government = 0;

Q.in_right_coalition = 0;
// Weimar coalition = ip + fp + lp
Q.in_weimar_coalition = 0;
// Grand coalition = ip + fp + lp + dp
// also includes the "new grand coalition" of ip + fp + BVP + lp + dp + Others
Q.in_grand_coalition = 0;
// Popular front = ip + cp + fp + lp
Q.in_popular_front = 0;
// left coalition = ip + cp + left-splinters
Q.in_left_front = 0;

// if you're in a coalition, this is an incremental counter for how many times dissent has happened from the right.
Q.coalition_dissent = 0;
// dissent from the cp, in a popular front or left front government
Q.cp_coalition_dissent = 0;

// does the ip tolerate the government even if it is not a participant?
Q.ip_toleration = 0;

// is the current government a presidential minority government?
Q.minority_government = 0;

// ministries - which parties control the ministries?
// starting with the 4th Marx cabinet https://en.wikipedia.org/wiki/Fourth_Marx_cabinet
// is the agricultural ministry useful at all?
Q.foreign_minister = 'Streseman';
Q.foreign_minister_party = 'dp';
Q.interior_minister = 'von Keudell';
Q.interior_minister_party = 'DNVP';
Q.justice_minister = 'Hergt';
