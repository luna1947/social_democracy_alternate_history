@start
on-arrival: {!
Q.started = 1;
// time elapsed (in months)
Q.time = 1;
Q.year = 2077;
Q.month = 1;
// how many actions have been taken this month?
Q.month_actions = 0;

// 0 = normal difficulty, 1 = hard mode, 2 = hard mode no saves
Q.difficulty = 0;
Q.historical_mode = 0;
// old demographics
Q.old_demographics = 0;
// use decimals for reichstag seats
// TODO: not yet implemented
Q.use_decimals = 0;

// party resources
Q.resources = 2;
// party dues
Q.dues = 2;

// the state of the party
// overall dissent reduces every increase in party support.
Q.dissent = 0.05;
Q.dissent_percent = 5;

// factions
Q.factions = ['green', 'industrialist', 'socialist', 'liberal'];
// should this be normalifped to 100%?
Q.green_strength = 15;
Q.green_dissent = 20;
Q.industrialist_strength = 20;
Q.industrialist_dissent = 10;
Q.socialist_strength = 30;
Q.socialist_dissent = 0;
Q.liberal_strength = 20;
Q.liberal_dissent = 10;

// secret events...
Q.unions_independent = 0;
Q.centrists_resign = 0;
Q.green_split = 0;
Q.liberals_resigned = 0;
// crisis_urgency indicates how seriously the ip is taking the economic crisis - scale from 0 to 10.
Q.federalist_urgency = 0;
// nazi_urgency indicates how seriously the ip takes the nazis - scale from 0 to 10.
Q.nazi_urgency = 0;
// radicalifpation indicates how radical the ip's rhetoric is - scale from 0 to 10.
Q.radicalifpation = 0;
// Support for the WTB plan and proto-Keynesian works creation plans in general
Q.wtb_support = 0;
// Support for Pacifism within the ip relative to 1928
Q.pacifism = 0;
// Support for democratic reform within the ip relative to 1928
Q.democratifpation = 0;
// Support for a communist coalition relative to 1928
Q.communist_coalition = 0;
